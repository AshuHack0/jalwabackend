PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/jalwa

# Backend production URL (must be publicly reachable by the payment gateway for callbacks)
BACKEND_URL=https://your-api-domain.com
# Deep link scheme for the mobile app — users are redirected here after payment
APP_FRONTEND_URL=jalwaapp://

# JWT
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=30d

# Invite code
INVITE_CODE=123456

# Mcgindiamc Gateway
MCGINDIAMC_GATEWAY_URL=https://mcapi.mcgindiamc.com
MCGINDIAMC_ACCESS_KEY=
MCGINDIAMC_ACCESS_SECRET=
MCGINDIAMC_CHANNEL_CODE=71001

# Oxoxmg Gateway
OXOXMG_GATEWAY_URL=https://mcapi.oxoxmg.com
OXOXMG_MERCHANT_ID=
OXOXMG_MD5_KEY=
OXOXMG_PASSAGE_CODE=100001

# USDT Gateway
USDT_GATEWAY_URL=https://your-usdt-gateway.com
USDT_ACCESS_KEY=
USDT_ACCESS_SECRET=
